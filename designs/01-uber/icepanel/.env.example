# Template — copy to .env and fill in. The real .env is gitignored.

# Profile settings -> API keys -> Create API key (shown only once)
ICEPANEL_API_KEY=

# From the landscape URL: app.icepanel.io/landscapes/<THIS>/...
ICEPANEL_LANDSCAPE_ID=

# Leave as "latest" (the current editable version)
ICEPANEL_VERSION_ID=latest
